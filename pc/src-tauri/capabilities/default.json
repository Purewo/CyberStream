{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main CyberStream window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "potplayer://**" },
        { "url": "vlc://**" },
        { "url": "iina://**" },
        { "url": "nplayer-**" },
        { "url": "infuse://**" },
        { "url": "intent:**" },
        { "url": "mailto:*" }
      ]
    },
    "dialog:default",
    "store:default",
    "clipboard-manager:default"
  ]
}
