# Local runtime overrides for CyberStream backend.
# Copy to .env.local and fill secrets. .env.local is intentionally ignored.

# Minimal private deployment guard. When set, management APIs require:
# Authorization: Bearer <token> or X-Cyber-API-Token: <token>.
# Health checks and public media/image streaming GETs remain accessible.
CYBER_API_TOKEN=
CYBER_AUTH_ENABLED=true

# Optional multi-user mode. Default is off so existing deployments keep working.
# When enabled, browser clients authenticate with an HttpOnly cookie session.
# CYBER_API_TOKEN remains a break-glass admin token.
CYBER_USER_MANAGEMENT_ENABLED=false
CYBER_SESSION_SECRET=
CYBER_SESSION_COOKIE_SECURE=false
CYBER_SESSION_DAYS=30
CYBER_LOGIN_RATE_LIMIT_ENABLED=true
CYBER_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
CYBER_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
CYBER_LOGIN_RATE_LIMIT_LOCK_SECONDS=900
CYBER_BOOTSTRAP_ADMIN_USERNAME=
CYBER_BOOTSTRAP_ADMIN_PASSWORD=
CYBER_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator

# Metadata provider secrets. Keep real values only in .env.local.
TMDB_TOKEN=

# Super CDN poster layer. Keep video streaming on the normal storage provider.
CYBER_CDN_PROVIDER=supercdn
CYBER_SUPERCDN_ENABLED=true
CYBER_SUPERCDN_URL=https://qwk.ccwu.cc
CYBER_SUPERCDN_TOKEN=
CYBER_SUPERCDN_BUCKET=hd-wallpapers
CYBER_SUPERCDN_BUCKET_NAME='高清壁纸桶'
CYBER_SUPERCDN_BUCKET_DESCRIPTION='CyberStream poster images'
CYBER_SUPERCDN_BUCKET_ALLOWED_TYPES=image
CYBER_SUPERCDN_ROUTE_PROFILE=china_all
CYBER_SUPERCDN_AUTO_UPLOAD_IMAGES=true
CYBER_SUPERCDN_AUTO_UPLOAD_SUBTITLES=false
CYBER_SUPERCDN_SERVE_ASSET_URLS=true
CYBER_SUPERCDN_TIMEOUT_SECONDS=120
