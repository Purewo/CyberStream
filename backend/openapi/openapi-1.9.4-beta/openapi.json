              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "未找到指定存储源"
          }
        }
      },
      "patch": {
        "summary": "🟠 [已开发未验证] 更新存储源配置",
        "description": "更新存储源的连接信息或别名。",
        "operationId": "updateStorageSource",
        "x-lifecycle-status": "implemented_unverified",
        "tags": [
          "Storage"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "存储源 ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StorageSourceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/storage/preview": {
      "post": {
        "summary": "🔵 [新增] 预览/浏览存储源目录",
        "description": "在不保存存储源的情况下，测试连接并浏览远程目录结构。",
        "operationId": "previewStorage",
        "x-lifecycle-status": "implemented_unverified",
        "tags": [
          "Storage"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StoragePreviewRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "目录列表",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/FileItem"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "连接失败或配置错误",
