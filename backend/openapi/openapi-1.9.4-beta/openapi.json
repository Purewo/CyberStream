              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/storage/sources/{id}/scan": {
      "post": {
        "summary": "✅ [验证通过] 扫描指定存储源",
        "description": "仅对指定的存储源（如某个 WebDAV）触发扫描，实现数据隔离更新。",
        "operationId": "scanSource",
        "x-lifecycle-status": "stable",
        "tags": [
          "Storage"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "存储源 ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "扫描任务已接受",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "msg": {
            "type": "string",
            "example": "success"
          },
          "trace_id": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "total_items": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          }
        }
      },
      "ScanStatus": {
        "type": "object",
        "description": "实时扫描状态",
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "idle",
              "scanning",
              "stopping"
            ],
            "example": "scanning"
          },
          "progress": {
            "type": "number",
            "description": "进度百分比 (0-100)",
            "example": 45.5
          },
          "current_file": {
            "type": "string",
            "example": "Avatar.2009.mkv"
          },
          "speed": {
            "type": "string",
            "description": "处理速度",
            "example": "15 items/s"
          },
          "remaining_time": {
            "type": "string",
            "example": "2m 30s"
          }
        }
      },
      "Genre": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Action"
          },
          "slug": {
            "type": "string",
            "description": "URL友好的标识符",
            "example": "action"
          },
          "count": {
            "type": "integer",
            "description": "该分类下的影片数量",
            "example": 156
          }
        }
      },
      "Region": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "United States"
          },
          "code": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 代码",
            "example": "US"
          },
          "count": {
            "type": "integer",
            "description": "该地区下的影片数量",
            "example": 420
          }
        }
      },
      "YearStats": {
        "type": "object",
        "properties": {
          "year": {
            "type": "integer",
            "example": 2023
          },
          "count": {
            "type": "integer",
            "example": 85
          }
        }
      },
      "FilterDictionaries": {
        "type": "object",
        "description": "全局筛选字典集合，包含所有用于前端筛选器的数据",
        "properties": {
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Genre"
            }
          },
          "years": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/YearStats"
            }
          },
          "countries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Region"
            }
          }
        }
      },
      "FileItem": {
        "type": "object",
        "description": "文件或目录项，用于预览接口",
        "properties": {
          "name": {
            "type": "string",
            "example": "Interstellar (2014)"
          },
          "path": {
            "type": "string",
            "description": "相对路径或完整路径",
            "example": "/Movies/Interstellar (2014)"
          },
          "type": {
            "type": "string",
            "enum": [
              "file",
              "dir"
            ],
            "example": "dir"
          },
          "size": {
            "type": "integer",
            "nullable": true,
            "description": "文件大小(字节)，目录可能为null"
          },
          "last_modified": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "extension": {
            "type": "string",
            "nullable": true,
            "example": "mkv"
          },
          "mime_type": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "StoragePreviewRequest": {
        "type": "object",
        "description": "预览请求，不需提供 name",
        "required": [
          "type",
          "config"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "local",
              "webdav",
              "smb",
              "ftp",
              "sftp"
            ],
            "description": "存储协议类型"
          },
          "target_path": {
            "type": "string",
            "default": "/",
            "description": "希望浏览的目录路径"
          },
          "config": {
            "description": "连接配置信息",
            "oneOf": [
              {
                "$ref": "#/components/schemas/ConfigLocal"
              },
              {
                "$ref": "#/components/schemas/ConfigWebDAV"
              },
              {
                "$ref": "#/components/schemas/ConfigSMB"
              },
              {
                "$ref": "#/components/schemas/ConfigFTP"
              },
              {
                "$ref": "#/components/schemas/ConfigSFTP"
              }
            ]
          }
        }
      },
      "StorageSource": {
        "type": "object",
        "description": "存储源配置实体",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Home NAS SMB"
          },
          "type": {
            "type": "string",
            "enum": [
              "local",
              "smb",
              "webdav",
              "ftp",
              "sftp"
            ],
            "example": "smb"
          },
          "root_path": {
            "type": "string",
            "description": "显示给前端的路径摘要"
          },
          "status": {
            "type": "string",
            "enum": [
              "online",
              "offline",
              "scanning"
            ]
          }
        }
      },
      "StorageSourceRequest": {
        "type": "object",
        "description": "添加存储源请求体",
        "required": [
          "name",
          "type",
          "config"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "My Cloud Disk",
            "description": "自定义别名"
          },
          "type": {
            "type": "string",
            "enum": [
              "local",
              "webdav",
              "smb",
              "ftp",
              "sftp"
            ],
            "description": "存储协议类型"
          },
          "config": {
            "description": "根据协议类型动态变化的配置对象",
            "oneOf": [
              {
                "$ref": "#/components/schemas/ConfigLocal"
              },
              {
                "$ref": "#/components/schemas/ConfigWebDAV"
              },
              {
                "$ref": "#/components/schemas/ConfigSMB"
              },
              {
                "$ref": "#/components/schemas/ConfigFTP"
              },
              {
                "$ref": "#/components/schemas/ConfigSFTP"
              }
            ]
          }
        }
      },
      "ConfigLocal": {
        "type": "object",
        "title": "Local Config",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "服务器本地绝对路径",
            "example": "/data/media/movies"
          }
        }
      },
      "ConfigWebDAV": {
        "type": "object",
        "title": "WebDAV Config",
        "required": [
          "host",
          "username",
          "password"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "域名或IP (不含 http 前缀)"
          },
          "port": {
            "type": "integer",
            "default": 443
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "secure": {
            "type": "boolean",
            "default": true,
            "description": "True=HTTPS, False=HTTP"
          },
          "root": {
            "type": "string",
            "default": "/",
            "description": "WebDAV 挂载根路径"
          }
        }
      },
      "ConfigSMB": {
        "type": "object",
        "title": "SMB Config",
        "required": [
          "host",
          "share",
          "username",
          "password"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "SMB服务器地址 (server_name)"
          },
          "share": {
            "type": "string",
            "description": "共享文件夹名称 (share_name)"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "default": 445
          },
          "workgroup": {
            "type": "string",
            "description": "Workgroup 或 Domain"
          }
        }
      },
      "ConfigFTP": {
        "type": "object",
        "title": "FTP Config",
        "required": [
          "host",
          "username",
          "password"
        ],
        "properties": {
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "default": 21
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ConfigSFTP": {
        "type": "object",
        "title": "SFTP Config",
        "required": [
          "host",
          "username",
          "password"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "域名或IP (不含 http 前缀)"
          },
          "port": {
            "type": "integer",
            "default": 22
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "secure": {
            "type": "boolean",
            "default": true,
            "description": "True=HTTPS, False=HTTP"
          },
          "root": {
            "type": "string",
            "default": "/",
            "description": "SFTP 挂载根路径"
          }
        }
      },
      "MovieSimple": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "poster_url": {
            "type": "string"
          },
          "rating": {
            "type": "number"
          },
          "year": {
            "type": "integer"
          },
          "country": {
            "type": "string",
            "description": "主要地区/国家代码 (如 'US', 'CN')",
            "example": "US"
          },
          "genres": {
            "type": "array",
            "description": "电影分类/标签",
            "items": {
              "type": "string"
            }
          },
          "source_ids": {
            "type": "array",
            "description": "该电影存在于哪些存储源ID中",
            "items": {
              "type": "integer"
            }
          },
          "user_data": {
            "type": "object",
            "description": "用户相关状态",
            "properties": {
              "is_played": {
                "type": "boolean"
              },
              "last_played_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "MovieDetailed": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MovieSimple"
          },
          {
            "type": "object",
            "properties": {
              "original_title": {
                "type": "string"
              },
              "overview": {
                "type": "string"
              },
              "backdrop_url": {
                "type": "string"
              },
              "resources": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          }
        ]
      },
      "Resource": {
        "type": "object",
        "description": "具体的视频文件资源，包含来源信息",
        "properties": {
          "id": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "source_id": {
            "type": "integer",
            "description": "所属存储源 ID"
          },
          "source_name": {
            "type": "string",
            "example": "Home NAS"
          },
          "protocol": {
            "type": "string",
            "example": "smb"
          },
          "relative_path": {
            "type": "string",
            "description": "相对于存储源根目录的路径，非绝对路径"
          },
          "quality_label": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "description": "文件大小"
          },
          "container": {
            "type": "string",
            "example": "mkv"
          },
          "media_info": {
            "type": "object",
            "description": "详细媒体编码信息",
            "properties": {
              "video_codec": {
                "type": "string",
                "example": "hevc"
              },
              "audio_codec": {
                "type": "string",
                "example": "truehd"
              },
              "resolution": {
                "type": "string",
                "example": "3840x2160"
              },
              "bitrate": {
                "type": "integer",
                "description": "Kbps",
                "example": 24500
              }
            }
          }
        }
      },
      "Subtitle": {
        "type": "object",
        "description": "字幕文件信息",
        "properties": {
          "id": {
            "type": "string",
            "description": "字幕文件的资源 ID"
          },
          "title": {
            "type": "string",
            "example": "Chinese (Simplified)"
          },
          "language": {
            "type": "string",
            "example": "chi"
          },
          "format": {
            "type": "string",
            "example": "srt"
          },
          "is_external": {
            "type": "boolean",
            "description": "true=外挂字幕, false=内嵌字幕"
          },
          "source_path": {
            "type": "string",
            "description": "字幕文件相对路径"
          }
        }
      }
    }
  }
}